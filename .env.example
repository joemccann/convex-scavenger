# IB Gateway connection
# IB_GATEWAY_HOST=127.0.0.1    # Local Docker (default)
# IB_GATEWAY_HOST=ib-gateway    # Cloud (Tailscale MagicDNS)
# IB_GATEWAY_PORT=4001
# IB_GATEWAY_MODE=docker        # "docker" (default) | "cloud" (remote, no restart) | "launchd"

